# Scholar MCP environment variables (copy to .env and fill in).

# --- Server ---
# SCHOLAR_MCP_TRANSPORT=stdio   # stdio | http | sse
# SCHOLAR_MCP_HOST=127.0.0.1
# SCHOLAR_MCP_PORT=8000
# SCHOLAR_MCP_HTTP_PATH=/mcp
# SCHOLAR_MCP_BASE_URL=https://mcp.example.com

# --- Auth (pick one flavor) ---
# SCHOLAR_MCP_BEARER_TOKEN=<secret>

# SCHOLAR_MCP_OIDC_CONFIG_URL=https://auth.example.com/.well-known/openid-configuration
# SCHOLAR_MCP_OIDC_CLIENT_ID=<client-id>
# SCHOLAR_MCP_OIDC_CLIENT_SECRET=<client-secret>
# SCHOLAR_MCP_OIDC_AUDIENCE=
# SCHOLAR_MCP_OIDC_REQUIRED_SCOPES=openid
# SCHOLAR_MCP_OIDC_JWT_SIGNING_KEY=<hex-string>

# --- Domain (populate from your ProjectConfig) ---
