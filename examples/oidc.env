# OIDC authentication example
# See docs/guides/authentication.md for setup instructions

SCHOLAR_MCP_BASE_URL=https://mcp.example.com
SCHOLAR_MCP_OIDC_CONFIG_URL=https://auth.example.com/.well-known/openid-configuration
SCHOLAR_MCP_OIDC_CLIENT_ID=mcp-client
SCHOLAR_MCP_OIDC_CLIENT_SECRET=your-client-secret
SCHOLAR_MCP_OIDC_JWT_SIGNING_KEY=your-signing-key   # openssl rand -hex 32
SCHOLAR_MCP_READ_ONLY=false
