# /etc/scholar-mcp/env — EnvironmentFile for the systemd service.
# Uncomment and edit settings as needed. Lines starting with # are ignored.
# See https://pvliesdonk.github.io/scholar-mcp/configuration/ for full docs.

# ---------------------------------------------------------------------------
# Semantic Scholar
# ---------------------------------------------------------------------------

# Semantic Scholar API key (optional; unauthenticated rate limit applies without it).
#SCHOLAR_MCP_S2_API_KEY=

# ---------------------------------------------------------------------------
# Cache
# ---------------------------------------------------------------------------

# Directory for the SQLite cache database. (default: /data/scholar-mcp)
SCHOLAR_MCP_CACHE_DIR=/var/lib/scholar-mcp

# ---------------------------------------------------------------------------
# PDF Conversion (optional — requires a running docling-serve instance)
# ---------------------------------------------------------------------------

# Base URL of a running docling-serve instance (e.g. http://localhost:5001).
#SCHOLAR_MCP_DOCLING_URL=

# OpenAI-compatible VLM endpoint for formula/figure-enriched PDF conversion.
#SCHOLAR_MCP_VLM_API_URL=
#SCHOLAR_MCP_VLM_API_KEY=
#SCHOLAR_MCP_VLM_MODEL=gpt-4o

# ---------------------------------------------------------------------------
# OpenAlex polite pool
# ---------------------------------------------------------------------------

# Contact email for OpenAlex polite pool (improves rate limits).
#SCHOLAR_MCP_CONTACT_EMAIL=

# ---------------------------------------------------------------------------
# Server Identity & Logging
# ---------------------------------------------------------------------------

# Read-only mode disables write tools (fetch_paper_pdf etc.). (default: true)
#SCHOLAR_MCP_READ_ONLY=true

# Log level: DEBUG, INFO, WARNING, ERROR. (default: INFO)
#SCHOLAR_MCP_LOG_LEVEL=INFO

# HTTP endpoint path prefix. (default: /mcp)
#SCHOLAR_MCP_HTTP_PATH=/mcp

# ---------------------------------------------------------------------------
# Authentication (optional — leave all unset for no auth)
# ---------------------------------------------------------------------------

# Simple bearer token auth. When set, clients must present this token.
#SCHOLAR_MCP_BEARER_TOKEN=

# Base URL for OIDC callback routing (e.g. https://mcp.example.com).
#SCHOLAR_MCP_BASE_URL=

# OIDC discovery URL (e.g. https://auth.example.com/.well-known/openid-configuration).
#SCHOLAR_MCP_OIDC_CONFIG_URL=

# OIDC client credentials (required for OIDC auth).
#SCHOLAR_MCP_OIDC_CLIENT_ID=
#SCHOLAR_MCP_OIDC_CLIENT_SECRET=

# Signing key for OIDC session JWTs. Critical on Linux — ephemeral default
# invalidates tokens on restart. Generate with: openssl rand -hex 32
#SCHOLAR_MCP_OIDC_JWT_SIGNING_KEY=
